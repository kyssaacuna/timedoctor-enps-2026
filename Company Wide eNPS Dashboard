<script>
const views = ['v0','v1','v2','v3'];
let chartsReady = false;

function goTo(i, btn) {
  views.forEach(id => document.getElementById(id).classList.remove('on'));
  document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('act'));
  document.getElementById(views[i]).classList.add('on');
  btn.classList.add('act');
  window.scrollTo({top:0,behavior:'smooth'});
  if (i === 1 && !chartsReady) { initCharts(); chartsReady = true; }
}

function showQ(type, btn) {
  document.querySelectorAll('.qpanel').forEach(p => p.classList.remove('on'));
  document.querySelectorAll('.q-tab').forEach(b => b.classList.remove('act'));
  document.getElementById('q' + type).classList.add('on');
  btn.classList.add('act');
}

function animCount(el, target, suffix, decimals, duration) {
  let start = 0;
  const step = target / (duration / 16);
  const tick = () => {
    start = Math.min(start + step, target);
    el.textContent = decimals ? start.toFixed(decimals) + suffix : Math.round(start) + suffix;
    if (start < target) requestAnimationFrame(tick);
  };
  tick();
}

function animGauge() {
  const arc = document.getElementById('gauge-arc');
  const full = 452;
  const target = full - (58 / 100) * full;
  setTimeout(() => { arc.style.strokeDashoffset = target; }, 300);
  animCount(document.getElementById('score-count'), 58, '', 0, 1300);
  animCount(document.getElementById('cnt-people'), 125, '', 0, 1000);
  animCount(document.getElementById('cnt-part'), 87, '%', 0, 1000);
  animCount(document.getElementById('cnt-avg'), 8.78, '', 2, 1000);
}
animGauge();

function initCharts() {
  setTimeout(() => {
    document.querySelectorAll('.theme-bar[data-w]').forEach(b => { b.style.width = b.dataset.w + '%'; });
    document.querySelectorAll('.prio-fill[data-w]').forEach(b => { b.style.width = b.dataset.w + '%'; });
  }, 100);

  new Chart(document.getElementById('scoreChart'), {
    type: 'bar',
    data: {
      labels: ['6', '7', '8', '9', '10'],
      datasets: [{ data: [3, 16, 31, 30, 45], backgroundColor: ['#A32D2D','#BA7517','#185FA5','#185FA5','#3B6D11'], borderRadius: 5 }]
    },
    options: {
      responsive: true, maintainAspectRatio: false,
      plugins: { legend: { display: false }, tooltip: { callbacks: { label: ctx => ' ' + ctx.raw + ' people' } } },
      scales: {
        x: { grid: { display: false }, ticks: { color: '#9CA3AF', font: { size: 12 } } },
        y: { display: false, beginAtZero: true, max: 55 }
      }
    }
  });
}
</script>
